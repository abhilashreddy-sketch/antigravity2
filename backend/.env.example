# Server Setup
PORT=5001
JWT_SECRET=supersecretjwttokenkeyforconstructiontrackerapp

# Database Configuration (Dialect: sqlite or mysql)
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# MySQL Setup (Optional, only used if DB_DIALECT=mysql)
DB_HOST=localhost
DB_USER=root
DB_PASS=password
DB_NAME=site_tracker_db

# Gemini AI API Configuration (Optional)
# If left blank, the app will fall back to the built-in rule-based analytical engine
GEMINI_API_KEY=

# Email SMTP Setup (Optional, fallback logs to console)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@constructionsitetracker.com
